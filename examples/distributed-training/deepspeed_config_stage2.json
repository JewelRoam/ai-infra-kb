{
    "deepspeed_config": {
        "train_batch_size": 256,
        "train_micro_batch_size_per_gpu": 16,
        "gradient_accumulation_steps": 4,
        
        "optimizer": {
            "type": "AdamW",
            "params": {
                "lr": 1e-4,
                "betas": [0.9, 0.999],
                "eps": 1e-8,
                "weight_decay": 0.01
            }
        },
        
        "scheduler": {
            "type": "WarmupDecayLR",
            "params": {
                "warmup_min_lr": 0,
                "warmup_max_lr": 1e-4,
                "warmup_num_steps": 1000,
                "total_num_steps": 100000
            }
        },
        
        "fp16": {
            "enabled": true,
            "loss_scale": 0,
            "loss_scale_window": 1000,
            "hysteresis": 2,
            "min_loss_scale": 1
        },
        
        "bf16": {
            "enabled": false
        },
        
        "gradient_clipping": 1.0,
        
        "zero_optimization": {
            "stage": 2,
            "offload_optimizer": {
                "device": "cpu",
                "pin_memory": true
            },
            "allgather_partitions": true,
            "allgather_bucket_size": 5e8,
            "overlap_comm": true,
            "reduce_scatter": true,
            "reduce_bucket_size": 5e8,
            "contiguous_gradients": true
        },
        
        "activation_checkpointing": {
            "partition_activations": true,
            "cpu_checkpointing": true,
            "contiguous_memory_optimization": false,
            "number_checkpoints": 1,
            "synchronize_checkpoint_boundary": false,
            "profile": false
        },
        
        "tensorboard": {
            "enabled": true,
            "output_path": "./logs",
            "job_name": "deepspeed_training"
        },
        
        "comms_logger": {
            "enabled": false
        },
        
        "wall_clock_breakdown": false,
        
        "flops_profiler": {
            "enabled": true,
            "profile_step": 10,
            "module_depth": -1,
            "top_modules": 3,
            "detailed": true
        },
        
        "checkpoint": {
            "tag_validation": "warn",
            "load_universal": false
        },
        
        "data_types": {
            "grad_accum_dtype": "fp32"
        }
    }
}